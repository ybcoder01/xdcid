APOTHEM_RPC_URL=https://erpc.apothem.network
NEXT_PUBLIC_APOTHEM_RPC_URL=https://rpc.apothem.network
XDC_MAINNET_RPC_URL=https://earpc.xinfin.network
NEXT_PUBLIC_XDC_RPC_URL=https://rpc.xdcrpc.com

# Server-only API settings. Never put private provider URLs in NEXT_PUBLIC_* variables.
XDC_RPC_URLS=https://rpc.xdcrpc.com,https://earpc.xinfin.network
XDC_RPC_TIMEOUT_MS=3500
XDC_API_CACHE_TTL_MS=15000

# Server-only distributed rate limiting. Leave blank until the Redis service is connected.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
API_RATE_LIMIT_HASH_SALT=
API_RATE_LIMIT_MAX_REQUESTS=60
API_RATE_LIMIT_WINDOW_SECONDS=60
API_RATE_LIMIT_REDIS_TIMEOUT_MS=2000

PRIVATE_KEY=0x...
NEXT_PUBLIC_XNS_REGISTRY=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_XNS_REGISTRAR=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_XNS_RESOLVER=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_XNS_REVERSE_RESOLVER=0x0000000000000000000000000000000000000000
